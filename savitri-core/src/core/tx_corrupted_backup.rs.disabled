    fn pre_verified_tx_overlay_skips_verification() -> anyhow::Result<()> {
        let tmp = unique_tmp_dir()?;
        let store = Storage::new(&tmp)?;

        let kp = generate_keypair();
        let from_pub = kp.public.to_bytes();
        let mut batch = store.begin_batch();
        batch.put_account(&from_pub, &Account { balance: 1000, nonce: 0 })?;
        batch.commit()?;

        // Create tx with pre_verified = true but invalid signature
        let mut tx = make_signed_tx(from_pub, b"bob".to_vec(), 5, &kp);
        tx.sig[0] ^= 0xFF; // corrupt signature
        tx.pre_verified = true; // Mark as pre-verified

        let mut overlay = BTreeMap::new();
        let mut receipts = Vec::new();
        let rc = apply_signed_tx_overlay(
            &store,
            &mut overlay,
            &mut receipts,
            &bincode::serialize(&tx)?,
            6,
        )?;
        // Should succeed because verification is skipped
        assert!(rc.status);

        // Balance should be updated in overlay
        let acc = overlay.get(from_pub.as_slice()).cloned().unwrap_or_default();
        assert_eq!(acc.balance, 995);
        Ok(())
    }

    #[test]
    fn non_pre_verified_tx_still_verifies() -> anyhow::Result<()> {
        let tmp = unique_tmp_dir()?;
        let store = Storage::new(&tmp)?;

        let kp = generate_keypair();
        let from_pub = kp.public.to_bytes();
        let mut batch = store.begin_batch();
        batch.put_account(&from_pub, &Account { balance: 1000, nonce: 0 })?;
        batch.commit()?;

        // Create tx with pre_verified = false and invalid signature
        let mut tx = make_signed_tx(from_pub, b"bob".to_vec(), 5, &kp);
        tx.sig[0] ^= 0xFF; // corrupt signature
        tx.pre_verified = false; // Not pre-verified, should verify

        let mut batch2 = store.begin_batch();
        let rc = apply_signed_tx(&store, &mut batch2, &bincode::serialize(&tx)?, 7)?;
        // Should fail because verification catches invalid signature
        assert!(!rc.status);
        assert!(rc.error.is_some());
        assert!(rc.error.unwrap().contains("signature error"));
        batch2.commit()?;

        // Balance should remain unchanged
        let acc = store.get_account(from_pub)?;
        assert_eq!(acc.balance, 1000);
        Ok(())
    }

