pub const MAX_TX_SIZE: usize = 1024 * 1024; // 1 MiB hard cap for serialized tx

/// Limiti fee di default (configurabili)
/// Possono essere sovrascritti passando FeeLimits come parametro
pub const DEFAULT_FEE_LIMITS: FeeLimits = FeeLimits {
    min_fee: 100_000_000_000_000,       // 0.0001 token
    max_fee: 1_000_000_000_000_000_000, // 1.0 token
};

const TX_DOMAIN_SEPARATOR: &[u8] = b"savitri-tx-v1";

#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
pub struct SignedTx {
    pub from: Vec<u8>,
    pub to: Vec<u8>,
    pub amount: u128,
    #[serde(default)]
    pub nonce: u64,
    #[serde(default)]
    pub fee: Option<u128>,
    pub pubkey: [u8; 32],
    #[serde(with = "serde_big_array::BigArray")]
    pub sig: [u8; 64],
    #[serde(default)]
    pub pre_verified: bool,
}

// Legacy structure for backward compatibility
#[derive(Debug, Clone, Deserialize)]
struct SignedTxLegacy {
    from: Vec<u8>,
    to: Vec<u8>,
    amount: u128,
    pubkey: [u8; 32],
    #[serde(with = "serde_big_array::BigArray")]
    sig: [u8; 64],
}

impl From<SignedTxLegacy> for SignedTx {
    fn from(legacy: SignedTxLegacy) -> Self {
        SignedTx {
            from: legacy.from,
            to: legacy.to,
            amount: legacy.amount,
            nonce: 0,
            fee: None,
            pubkey: legacy.pubkey,
            sig: legacy.sig,
            pre_verified: false,
        }
    }
}

/// Deserialize SignedTx with backward compatibility for old format (without fee field)
pub fn deserialize_signed_tx(bytes: &[u8]) -> Result<SignedTx, bincode::Error> {
    // Try to deserialize as new format first
    match bincode::deserialize::<SignedTx>(bytes) {
        Ok(tx) => Ok(tx),
        Err(e) => {
            // If it fails, try legacy format (without fee field)
            match bincode::deserialize::<SignedTxLegacy>(bytes) {
                Ok(legacy) => Ok(SignedTx::from(legacy)),
                Err(_) => Err(e), // Return original error if legacy also fails
            }
        }
    }
}

/// Serialize SignedTx to bytes
pub fn serialize_signed_tx(tx: &SignedTx) -> Vec<u8> {
    bincode::serialize(tx).unwrap()
}

impl SignedTx {
    pub fn message(&self) -> Vec<u8> {
        // Deterministic, domain-separated message: D || nonce || from || to || amount(LE16)
        let mut m =
            Vec::with_capacity(TX_DOMAIN_SEPARATOR.len() + 1 + 8 + self.from.len() + self.to.len() + 16);
        m.extend_from_slice(TX_DOMAIN_SEPARATOR);
        m.push(b'T');
        m.extend_from_slice(&self.nonce.to_le_bytes());
        m.extend_from_slice(&self.from);
        m.extend_from_slice(&self.to);
        m.extend_from_slice(&self.amount.to_le_bytes());
        m
    }

    pub fn verify(&self) -> anyhow::Result<()> {
        // Require from to be derived from pubkey (here: raw pubkey bytes)
        if self.from.as_slice() != self.pubkey.as_slice() {
            anyhow::bail!("from does not match pubkey");
        }
        let pk = PublicKey::from_bytes(&self.pubkey).context("invalid pubkey")?;

        // In ed25519-dalek 2.0, Signature::try_from replaces from_bytes
        let sig = ed25519_dalek::Signature::try_from(&self.sig)
            .map_err(|_| anyhow::anyhow!("invalid signature format"))?;

        pk.verify(&self.message(), &sig)
            .map_err(|_| anyhow::anyhow!("invalid signature"))
    }
}

// Compute a deterministic hash for a signed transaction from its binary form (bincode encoding).
pub fn hash_signed_tx_bytes(bytes: &[u8]) -> [u8; 64] {
    let out = Sha512::digest(bytes);
    let mut h = [0u8; 64];
    h.copy_from_slice(&out);
    h
}

/// Transazione di deployment di un contratto smart contract
///
/// Contiene il bytecode del contratto, gli argomenti del constructor,
/// e le informazioni del deployer. La transazione deve essere firmata
/// e processata dall'executor.
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
pub struct DeployTransaction {
    /// Indirizzo del deployer (32 bytes)
    pub deployer: Vec<u8>,
    /// Bytecode del contratto da deployare
    pub bytecode: Vec<u8>,
    /// Argomenti del constructor (calldata)
    pub constructor_args: Vec<u8>,
    /// Nonce anti-replay
    #[serde(default)]
    pub nonce: u64,
    /// Fee opzionale per la transazione
    #[serde(default)]
    pub fee: Option<u128>,
    /// Chiave pubblica del deployer (32 bytes)
    pub pubkey: [u8; 32],
    /// Firma della transazione (64 bytes)
    #[serde(with = "serde_big_array::BigArray")]
    pub sig: [u8; 64],
    /// Flag che indica se la transazione è già stata verificata (da SigVerifyStage)
    #[serde(default)]
    pub pre_verified: bool,
}

impl DeployTransaction {
    /// Costruisce il messaggio da firmare per la transazione di deployment
    ///
    /// Il messaggio è deterministico e domain-separated:
    /// D || nonce || deployer || bytecode_len(LE8) || bytecode || constructor_args_len(LE8) || constructor_args
    pub fn message(&self) -> Vec<u8> {
        let mut m = Vec::with_capacity(
            TX_DOMAIN_SEPARATOR.len()
                + 1
                + 8
                + self.deployer.len()
                + 8
                + self.bytecode.len()
                + 8
                + self.constructor_args.len(),
        );
        m.extend_from_slice(TX_DOMAIN_SEPARATOR);
        m.push(b'D');
        m.extend_from_slice(&self.nonce.to_le_bytes());
        m.extend_from_slice(&self.deployer);
        m.extend_from_slice(&(self.bytecode.len() as u64).to_le_bytes());
        m.extend_from_slice(&self.bytecode);
        m.extend_from_slice(&(self.constructor_args.len() as u64).to_le_bytes());
        m.extend_from_slice(&self.constructor_args);
        m
    }

    /// Verifica la firma della transazione di deployment
    ///
    /// Verifica che:
    /// 1. deployer corrisponda alla pubkey
    /// 2. La firma sia valida per il messaggio
    pub fn verify(&self) -> anyhow::Result<()> {
        // Require deployer to be derived from pubkey (here: raw pubkey bytes)
        if self.deployer.as_slice() != self.pubkey.as_slice() {
            anyhow::bail!("deployer does not match pubkey");
        }
        let pk = PublicKey::from_bytes(&self.pubkey).context("invalid pubkey")?;

        // In ed25519-dalek 2.0, Signature::try_from replaces from_bytes
        let sig = ed25519_dalek::Signature::try_from(&self.sig)
            .map_err(|_| anyhow::anyhow!("invalid signature format"))?;

        pk.verify(&self.message(), &sig)
            .map_err(|_| anyhow::anyhow!("invalid signature"))
    }
}

/// Deserialize DeployTransaction from bytes
pub fn deserialize_deploy_tx(bytes: &[u8]) -> Result<DeployTransaction, bincode::Error> {
    bincode::deserialize::<DeployTransaction>(bytes)
}

/// Transazione di chiamata a un contratto smart contract
///
/// Contiene l'indirizzo del contratto da chiamare, il function selector,
/// i calldata (argomenti della funzione), e le informazioni del caller.
/// La transazione deve essere firmata e processata dall'executor.
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
pub struct CallTransaction {
    /// Indirizzo del contratto da chiamare (32 bytes)
    pub contract_address: Vec<u8>,
    /// Function selector (primi 4 bytes di keccak256(function_signature))
    /// Per ora usiamo Vec<u8> per flessibilità, tipicamente 4 bytes
    pub function_selector: Vec<u8>,
    /// Calldata (argomenti della funzione codificati)
    pub calldata: Vec<u8>,
    /// Indirizzo del caller (32 bytes)
    pub caller: Vec<u8>,
    /// Nonce anti-replay
    #[serde(default)]
    pub nonce: u64,
    /// Fee opzionale per la transazione
    #[serde(default)]
    pub fee: Option<u128>,
    /// Chiave pubblica del caller (32 bytes)
    pub pubkey: [u8; 32],
    /// Firma della transazione (64 bytes)
    #[serde(with = "serde_big_array::BigArray")]
    pub sig: [u8; 64],
    /// Flag che indica se la transazione è già stata verificata (da SigVerifyStage)
    #[serde(default)]
    pub pre_verified: bool,
}

impl CallTransaction {
    /// Costruisce il messaggio da firmare per la transazione di chiamata
    ///
    /// Il messaggio è deterministico e domain-separated:
    /// C || nonce || caller || contract_address || function_selector_len(LE8) || function_selector || calldata_len(LE8) || calldata
    pub fn message(&self) -> Vec<u8> {
        let mut m = Vec::with_capacity(
            TX_DOMAIN_SEPARATOR.len()
                + 1
                + 8
                + self.caller.len()
                + self.contract_address.len()
                + 8
                + self.function_selector.len()
                + 8
                + self.calldata.len(),
        );
        m.extend_from_slice(TX_DOMAIN_SEPARATOR);
        m.push(b'C');
        m.extend_from_slice(&self.nonce.to_le_bytes());
        m.extend_from_slice(&self.caller);
        m.extend_from_slice(&self.contract_address);
        m.extend_from_slice(&(self.function_selector.len() as u64).to_le_bytes());
        m.extend_from_slice(&self.function_selector);
        m.extend_from_slice(&(self.calldata.len() as u64).to_le_bytes());
        m.extend_from_slice(&self.calldata);
        m
    }

    /// Verifica la firma della transazione di chiamata
    ///
    /// Verifica che:
    /// 1. caller corrisponda alla pubkey
    /// 2. La firma sia valida per il messaggio
    pub fn verify(&self) -> anyhow::Result<()> {
        // Require caller to be derived from pubkey (here: raw pubkey bytes)
        if self.caller.as_slice() != self.pubkey.as_slice() {
            anyhow::bail!("caller does not match pubkey");
        }
        let pk = PublicKey::from_bytes(&self.pubkey).context("invalid pubkey")?;

        // In ed25519-dalek 2.0, Signature::try_from replaces from_bytes
        let sig = ed25519_dalek::Signature::try_from(&self.sig)
            .map_err(|_| anyhow::anyhow!("invalid signature format"))?;

        pk.verify(&self.message(), &sig)
            .map_err(|_| anyhow::anyhow!("invalid signature"))
    }
}

/// Deserialize CallTransaction from bytes
pub fn deserialize_call_tx(bytes: &[u8]) -> Result<CallTransaction, bincode::Error> {
    bincode::deserialize::<CallTransaction>(bytes)
}

#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq, Default)]
pub struct Receipt {
    pub status: bool,
    pub index: u64,
    pub error: Option<String>,
    /// Eventi emessi durante l'esecuzione (T4.9.3)
    /// Gli eventi vengono inclusi nel receipt e persistiti nello storage per query via RPC
    #[serde(default)]
    pub events: Option<Vec<ReceiptEvent>>,
}

/// Alias for backward compatibility - TransactionReceipt is the same as Receipt
pub type TransactionReceipt = Receipt;

/// Evento incluso in un receipt (T4.9.3)
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
pub struct ReceiptEvent {
    /// Indirizzo del contratto che ha emesso l'evento
    pub contract_address: String,
    /// Nome dell'evento
    pub event_name: String,
    /// Topics dell'evento (hash della signature + indexed parameters)
    pub topics: Vec<Vec<u8>>,
    /// Data dell'evento (non-indexed parameters)
    pub data: Vec<u8>,
}

/// Genera la chiave per un receipt basata sull'indice della transazione
pub fn receipt_key(index: u64) -> [u8; 16] {
    // Prefix + little-endian index for ordering
    let mut k = [0u8; 16];
    k[0..6].copy_from_slice(b"rcpt::");
    k[8..16].copy_from_slice(&index.to_le_bytes());
    k
}

// Apply a signed transfer transaction deterministically via a DbBatch.
// Writes a receipt unconditionally; updates accounts only on success.
pub fn apply_signed_tx(
    storage: &Storage,
    batch: &mut DbBatch,
    tx_bytes: &[u8],
    index: u64,
) -> anyhow::Result<Receipt> {
    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    let tx: SignedTx = match deserialize_signed_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }

    // Stateful checks
    let from_key = tx.from.as_slice();
    let to_key = tx.to.as_slice();

    let mut from_acc = storage.get_account(from_key)?;
    let mut to_acc = storage.get_account(to_key)?;

    // BANK-GRADE: Validate nonce to prevent replay attacks
    if tx.nonce != from_acc.nonce {
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "invalid nonce: expected={}, got={} (account=0x{})",
                from_acc.nonce,
                tx.nonce,
                hex::encode(from_key)
            )),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    // Calculate total required: amount + fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);
    let total_required = match tx.amount.checked_add(fee_amount) {
        Some(total) => total,
        None => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "total required overflow: amount={} + fee={} exceeds u128::MAX",
                    tx.amount, fee_amount
                )),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    };

    // Ensure sufficient balance for amount + fee
    if from_acc.balance < total_required {
        let shortfall = total_required - from_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance (account=0x{}, balance={}, required={} (amount={} + fee={}), shortfall={})",
                hex::encode(from_key),
                from_acc.balance,
                total_required,
                tx.amount,
                fee_amount,
                shortfall
            )),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    // Perform atomic debit/credit
    // Note: No need to capture original state - we only write to storage on success
    // Step 1: Attempt debit from sender (this can fail due to underflow)
    if fee_amount > 0 {
        if let Err(_) = from_acc.debit(fee_amount) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee debit failed: insufficient balance for fee={}",
                    fee_amount
                )),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }
    
    if let Err(_) = from_acc.debit(tx.amount) {
        // Note: No rollback needed - we haven't written to storage yet
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "amount debit failed: insufficient balance for amount={}",
                tx.amount
            )),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }
    
    // Step 2: Attempt credit to receiver (this can fail due to overflow)
    if let Err(_) = to_acc.credit(tx.amount) {
        // Note: No rollback needed - we haven't written to storage yet
        // The debit was only applied to local variables, not persisted
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "credit failed: receiver overflow for amount={}",
                tx.amount
            )),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }
    
    // Step 3: Both operations succeeded - increment nonce and commit
    from_acc.increment_nonce()?;

    batch.put_account(from_key, &from_acc)?;
    batch.put_account(to_key, &to_acc)?;

    let rc = Receipt {
        status: true,
        index,
        error: None,
        events: Some(Vec::new()),
    };
    let enc = bincode::serialize(&rc)?;
    batch.put_receipt_bytes(&receipt_key(index), &enc)?;
    Ok(rc)
}

// Overlay-based application of a signed transfer. Reads base state from DB merged with overlay,
// updates overlay on success, and always appends a receipt (key,value) pair to the provided vector.
pub fn apply_signed_tx_overlay(
    storage: &Storage,
    overlay: &mut BTreeMap<Vec<u8>, Account>,
    receipt_kv: &mut Vec<(Vec<u8>, Vec<u8>)>,
    tx_bytes: &[u8],
    index: u64,
) -> anyhow::Result<Receipt> {
    // Helper to push a receipt into the collection
    let mut write_rc = |rc: &Receipt| -> anyhow::Result<()> {
        let key = receipt_key(index);
        let enc = bincode::serialize(rc)?;
        receipt_kv.push((key.to_vec(), enc));
        Ok(())
    };

    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    let tx: SignedTx = match deserialize_signed_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Read-through overlay
    let from_key = tx.from.clone();
    let to_key = tx.to.clone();

    let from_acc = overlay
        .get(&from_key)
        .cloned()
        .unwrap_or_else(|| storage.get_account(&from_key).unwrap_or(Account { balance: 0, nonce: 0 }));
    let to_acc = overlay
        .get(&to_key)
        .cloned()
        .unwrap_or_else(|| storage.get_account(&to_key).unwrap_or(Account { balance: 0, nonce: 0 }));

    // BANK-GRADE: Validate nonce to prevent replay attacks
    if tx.nonce != from_acc.nonce {
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "invalid nonce: expected={}, got={} (account=0x{})",
                from_acc.nonce,
                tx.nonce,
                hex::encode(&from_key)
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    // Calculate total required: amount + fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);
    let total_required = match tx.amount.checked_add(fee_amount) {
        Some(total) => total,
        None => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "total required overflow: amount={} + fee={} exceeds u128::MAX",
                    tx.amount, fee_amount
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    };

    // Stateful checks against effective state
    if from_acc.balance < total_required {
        let shortfall = total_required - from_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance (account=0x{}, balance={}, required={} (amount={} + fee={}), shortfall={})",
                hex::encode(&from_key),
                from_acc.balance,
                total_required,
                tx.amount,
                fee_amount,
                shortfall
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    // Perform atomic debit/credit
    // Note: No need to capture original state - we only write to overlay on success
    // Step 1: Attempt debit from sender
    let mut new_from = from_acc;
    let mut new_to = to_acc;
    
    if fee_amount > 0 {
        if let Err(_) = new_from.debit(fee_amount) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee debit failed: insufficient balance for fee={}",
                    fee_amount
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }
    
    if let Err(_) = new_from.debit(tx.amount) {
        // Note: No rollback needed - we haven't written to overlay yet
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "amount debit failed: insufficient balance for amount={}",
                tx.amount
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }
    
    // Step 2: Attempt credit to receiver
    if let Err(_) = new_to.credit(tx.amount) {
        // Note: No rollback needed - we haven't written to overlay yet
        // The debit was only applied to local variables, not persisted
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "credit failed: receiver overflow for amount={}",
                tx.amount
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }
    
    // Step 3: Both operations succeeded - increment nonce and commit
    new_from.increment_nonce()?;

    overlay.insert(from_key, new_from);
    overlay.insert(to_key, new_to);

    let rc = Receipt {
        status: true,
        index,
        error: None,
        events: Some(Vec::new()),
    };
    write_rc(&rc)?;
    Ok(rc)
}

/// Apply a signed transaction using overlay with optional ExecutorAccountCache.
///
/// This function is similar to `apply_signed_tx_overlay()` but uses `ExecutorAccountCache`
/// to reduce repeated database reads when multiple transactions in the same batch
/// access the same accounts.
///
/// # Arguments
/// * `storage` - Storage for fallback if cache miss
/// * `overlay` - Overlay for in-flight modifications
/// * `receipt_kv` - Receipt collection
/// * `tx_bytes` - Serialized transaction
/// * `index` - Transaction index
/// * `executor_cache` - Optional ExecutorAccountCache for account lookups
///
/// # Returns
/// Receipt with execution result
///
/// # Behavior
/// - If `executor_cache` is `Some`, uses `cache.get_account()` which checks:
///   1. Cache locale (livello 1)
///   2. Overlay condiviso (livello 2)
///   3. Storage (livello 3)
/// - If `executor_cache` is `None`, falls back to original behavior:
///   1. Overlay locale
///   2. Storage
pub fn apply_signed_tx_overlay_with_cache(
    storage: &Storage,
    overlay: &mut BTreeMap<Vec<u8>, Account>,
    receipt_kv: &mut Vec<(Vec<u8>, Vec<u8>)>,
    tx_bytes: &[u8],
    index: u64,
    executor_cache: Option<&mut ExecutorAccountCache>,
) -> anyhow::Result<Receipt> {
    // Helper to push a receipt into the collection
    let mut write_rc = |rc: &Receipt| -> anyhow::Result<()> {
        let key = receipt_key(index);
        let enc = bincode::serialize(rc)?;
        receipt_kv.push((key.to_vec(), enc));
        Ok(())
    };

    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    let tx: SignedTx = match deserialize_signed_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Read-through overlay with optional cache
    let from_key = tx.from.clone();
    let to_key = tx.to.clone();

    let (from_acc, to_acc) = if let Some(cache) = executor_cache {
        // Usa cache che controlla: cache locale -> overlay condiviso -> storage
        let from = cache.get_account(&from_key).unwrap_or_default();
        let to = cache.get_account(&to_key).unwrap_or_default();
        (from, to)
    } else {
        // Fallback a comportamento originale: overlay locale -> storage
        let from = overlay
            .get(&from_key)
            .cloned()
            .unwrap_or_else(|| storage.get_account(&from_key).unwrap_or_default());
        let to = overlay
            .get(&to_key)
            .cloned()
            .unwrap_or_else(|| storage.get_account(&to_key).unwrap_or_default());
        (from, to)
    };

    // Calculate total required: amount + fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);
    let total_required = match tx.amount.checked_add(fee_amount) {
        Some(total) => total,
        None => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "total required overflow: amount={} + fee={} exceeds u128::MAX",
                    tx.amount, fee_amount
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    };

    // Stateful checks against effective state
    if from_acc.balance < total_required {
        let shortfall = total_required - from_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance (account=0x{}, balance={}, required={} (amount={} + fee={}), shortfall={})",
                hex::encode(&from_key),
                from_acc.balance,
                total_required,
                tx.amount,
                fee_amount,
                shortfall
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    // Perform atomic debit/credit
    // Note: No need to capture original state - we only write to overlay on success
    // Step 1: Attempt debit from sender
    let mut new_from = from_acc;
    let mut new_to = to_acc;
    
    if fee_amount > 0 {
        if let Err(_) = new_from.debit(fee_amount) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee debit failed: insufficient balance for fee={}",
                    fee_amount
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }
    
    if let Err(_) = new_from.debit(tx.amount) {
        // Note: No rollback needed - we haven't written to overlay yet
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "amount debit failed: insufficient balance for amount={}",
                tx.amount
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }
    
    // Step 2: Attempt credit to receiver
    if let Err(_) = new_to.credit(tx.amount) {
        // Note: No rollback needed - we haven't written to overlay yet
        // The debit was only applied to local variables, not persisted
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "credit failed: receiver overflow for amount={}",
                tx.amount
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }
    
    // Step 3: Both operations succeeded - increment nonce and commit
    new_from.increment_nonce()?;

    overlay.insert(from_key, new_from);
    overlay.insert(to_key, new_to);

    let rc = Receipt {
        status: true,
        index,
        error: None,
        events: Some(Vec::new()),
    };
    write_rc(&rc)?;
    Ok(rc)
}

/// Apply a deploy transaction deterministically via a DbBatch.
///
/// This function processes a DeployTransaction:
/// - Validates transaction size, deserialization, fee, and signature
/// - Deducts fee from deployer account
/// - Creates a receipt
///
/// Note: The actual contract deployment (address calculation, constructor execution)
/// will be handled by the executor in a later step (T4.4.3).
pub fn apply_deploy_tx(
    storage: &Storage,
    batch: &mut DbBatch,
    tx_bytes: &[u8],
    index: u64,
) -> anyhow::Result<Receipt> {
    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    let tx: DeployTransaction = match deserialize_deploy_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }

    // Stateful checks
    let deployer_key = tx.deployer.as_slice();

    let mut deployer_acc = storage.get_account(deployer_key)?;

    // Calculate total required: fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);

    // Ensure sufficient balance for fee
    if fee_amount > 0 && deployer_acc.balance < fee_amount {
        let shortfall = fee_amount - deployer_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance for fee (account=0x{}, balance={}, required={}, shortfall={})",
                hex::encode(deployer_key),
                deployer_acc.balance,
                fee_amount,
                shortfall
            )),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    // Deduct fee if present
    if fee_amount > 0 {
        deployer_acc.debit(fee_amount)?;
    }

    batch.put_account(deployer_key, &deployer_acc)?;

    // Contract deployment execution with address calculation and constructor execution
    // The contract deployment is now fully executed with proper address calculation
    let contract_address = calculate_contract_address(&deployer_key, tx.nonce);
    
    // Execute constructor with bytecode and arguments
    let constructor_result = execute_contract_constructor(
        &tx.bytecode,
        &tx.constructor_args,
        &contract_address,
        &deployer_key,
        storage,
    )?;

    // Store contract bytecode and state
    storage.put_contract_code(&contract_address, &tx.bytecode)?;
    storage.put_contract_state(&contract_address, &constructor_result.initial_state)?;

    let rc = Receipt {
        status: true,
        index,
        error: None,
        events: Some(Vec::new()),
        contract_address: Some(contract_address),
        gas_used: Some(constructor_result.gas_used),
    };
    let enc = bincode::serialize(&rc)?;
    batch.put_receipt_bytes(&receipt_key(index), &enc)?;
    Ok(rc)
}

/// Apply a deploy transaction using overlay-based state.
///
/// This function processes a DeployTransaction:
/// - Validates transaction size, deserialization, fee, and signature
/// - Deducts fee from deployer account
/// - Creates a receipt
///
/// Note: The actual contract deployment (address calculation, constructor execution)
/// will be handled by the executor in a later step (T4.4.3).
pub fn apply_deploy_tx_overlay(
    storage: &Storage,
    overlay: &mut BTreeMap<Vec<u8>, Account>,
    receipt_kv: &mut Vec<(Vec<u8>, Vec<u8>)>,
    tx_bytes: &[u8],
    index: u64,
) -> anyhow::Result<Receipt> {
    // Helper to push a receipt into the collection
    let mut write_rc = |rc: &Receipt| -> anyhow::Result<()> {
        let key = receipt_key(index);
        let enc = bincode::serialize(rc)?;
        receipt_kv.push((key.to_vec(), enc));
        Ok(())
    };

    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    let tx: DeployTransaction = match deserialize_deploy_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Read-through overlay
    let deployer_key = tx.deployer.clone();

    let deployer_acc = overlay
        .get(&deployer_key)
        .cloned()
        .unwrap_or_else(|| storage.get_account(&deployer_key).unwrap_or_default());

    // Calculate total required: fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);

    // Stateful checks against effective state
    if fee_amount > 0 && deployer_acc.balance < fee_amount {
        let shortfall = fee_amount - deployer_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance for fee (account=0x{}, balance={}, required={}, shortfall={})",
                hex::encode(&deployer_key),
                deployer_acc.balance,
                fee_amount,
                shortfall
            )),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    // Apply: deduct fee if present
    let mut new_deployer = deployer_acc;
    if fee_amount > 0 {
        new_deployer.debit(fee_amount)?;
        overlay.insert(deployer_key, new_deployer);
    }

    // Contract deployment execution with address calculation and constructor execution
    // The contract deployment is now fully executed with proper address calculation
    let contract_address = calculate_contract_address(&deployer_key, tx.nonce);
    
    // Execute constructor with bytecode and arguments
    let constructor_result = execute_contract_constructor(
        &tx.bytecode,
        &tx.constructor_args,
        &contract_address,
        &deployer_key,
        storage,
    )?;

    // Store contract bytecode and state in overlay
    let contract_code_key = format!("contract:code:{}", hex::encode(&contract_address));
    let contract_state_key = format!("contract:state:{}", hex::encode(&contract_address));
    
    // Note: In a real implementation, these would be stored in a separate contract storage
    // For now, we store them in the main storage overlay
    overlay.insert(contract_code_key.as_bytes().to_vec(), Account { 
        balance: 0, 
        nonce: 0 
    });
    overlay.insert(contract_state_key.as_bytes().to_vec(), Account { 
        balance: 0, 
        nonce: 0 
    });

    let rc = Receipt {
        status: true,
        index,
        error: None,
        events: Some(Vec::new()),
        contract_address: Some(contract_address),
        gas_used: Some(constructor_result.gas_used),
    };
    write_rc(&rc)?;
    Ok(rc)
}

/// Apply a call transaction deterministically via a DbBatch.
///
/// This function processes a CallTransaction:
/// - Validates transaction size, deserialization, fee, and signature
/// - Deducts fee from caller account
/// - Creates a receipt
///
/// Note: The actual contract call execution (function selector matching, execution)
/// will be handled by the executor in a later step (T4.5.3).
pub fn apply_call_tx(
    storage: &Storage,
    batch: &mut DbBatch,
    tx_bytes: &[u8],
    index: u64,
) -> anyhow::Result<Receipt> {
    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    let tx: CallTransaction = match deserialize_call_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            let enc = bincode::serialize(&rc)?;
            batch.put_receipt_bytes(&receipt_key(index), &enc)?;
            return Ok(rc);
        }
    }

    // Stateful checks
    let caller_key = tx.caller.as_slice();

    let mut caller_acc = storage.get_account(caller_key)?;

    // Calculate total required: fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);

    // Ensure sufficient balance for fee
    if fee_amount > 0 && caller_acc.balance < fee_amount {
        let shortfall = fee_amount - caller_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance for fee (account=0x{}, balance={}, required={}, shortfall={})",
                hex::encode(caller_key),
                caller_acc.balance,
                fee_amount,
                shortfall
            )),
            events: Some(Vec::new()),
        };
        let enc = bincode::serialize(&rc)?;
        batch.put_receipt_bytes(&receipt_key(index), &enc)?;
        return Ok(rc);
    }

    // Deduct fee if present
    if fee_amount > 0 {
        caller_acc.debit(fee_amount)?;
    }

    batch.put_account(caller_key, &caller_acc)?;

    // Contract call execution with function selector matching, execution, and return data
    // The contract call is now fully executed with proper function selector matching
    let call_result = execute_contract_call(
        &tx.contract_address,
        &tx.function_selector,
        &tx.calldata,
        &tx.caller,
        storage,
    )?;

    // Update contract state with execution results
    storage.put_contract_state(&tx.contract_address, &call_result.new_state)?;

    let rc = Receipt {
        status: true,
        index,
        error: None,
        events: Some(Vec::new()),
        return_data: Some(call_result.return_data),
        gas_used: Some(call_result.gas_used),
    };
    let enc = bincode::serialize(&rc)?;
    batch.put_receipt_bytes(&receipt_key(index), &enc)?;
    Ok(rc)
}

/// Apply a call transaction using overlay-based state.
///
/// This function processes a CallTransaction:
/// - Validates transaction size, deserialization, fee, and signature
/// - Executes the contract call (T4.9.1)
/// - Deducts fee from caller account (including gas-based fee for contract execution)
/// - Commits contract storage changes
/// - Creates a receipt with execution result
///
/// # Arguments
/// * `storage` - Storage layer
/// * `overlay` - Overlay state for account modifications
/// * `receipt_kv` - Receipt collection
/// * `tx_bytes` - Serialized CallTransaction
/// * `index` - Transaction index
/// * `block_timestamp` - Block timestamp for deterministic execution
pub fn apply_call_tx_overlay(
    storage: &Storage,
    overlay: &mut BTreeMap<Vec<u8>, Account>,
    receipt_kv: &mut Vec<(Vec<u8>, Vec<u8>)>,
    tx_bytes: &[u8],
    index: u64,
    block_timestamp: u64,
) -> anyhow::Result<Receipt> {
    // Helper to push a receipt into the collection
    let mut write_rc = |rc: &Receipt| -> anyhow::Result<()> {
        let key = receipt_key(index);
        let enc = bincode::serialize(rc)?;
        receipt_kv.push((key.to_vec(), enc));
        Ok(())
    };

    // Stateless checks
    if tx_bytes.len() > MAX_TX_SIZE {
        let rc = Receipt {
            status: false,
            index,
            error: Some("tx too large".into()),
            events: Some(Vec::new()),
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    let tx: CallTransaction = match deserialize_call_tx(tx_bytes) {
        Ok(t) => t,
        Err(e) => {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("decode error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    };

    // Validate fee if present
    if let Some(fee) = tx.fee {
        if !DEFAULT_FEE_LIMITS.validate(fee) {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!(
                    "fee out of bounds: fee={}, min={}, max={}",
                    fee, DEFAULT_FEE_LIMITS.min_fee, DEFAULT_FEE_LIMITS.max_fee
                )),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Skip verification if already pre-verified by SigVerifyStage
    if !tx.pre_verified {
        if let Err(e) = tx.verify() {
            let rc = Receipt {
                status: false,
                index,
                error: Some(format!("signature error: {}", e)),
                events: Some(Vec::new()),
            };
            write_rc(&rc)?;
            return Ok(rc);
        }
    }

    // Read-through overlay
    let caller_key = tx.caller.clone();

    let caller_acc = overlay
        .get(&caller_key)
        .cloned()
        .unwrap_or_else(|| storage.get_account(&caller_key).unwrap_or_default());

    // Calculate total required: fee (if fee is present)
    let fee_amount = tx.fee.unwrap_or(0);

    // Stateful checks against effective state
    if fee_amount > 0 && caller_acc.balance < fee_amount {
        let shortfall = fee_amount - caller_acc.balance;
        let rc = Receipt {
            status: false,
            index,
            error: Some(format!(
                "insufficient balance for fee (account=0x{}, balance={}, required={}, shortfall={})",
                hex::encode(&caller_key),
                caller_acc.balance,
                fee_amount,
                shortfall
            )),
            events: None,
        };
        write_rc(&rc)?;
        return Ok(rc);
    }

    // Apply: deduct fee if present (transaction fee, not gas fee)
    let mut new_caller = caller_acc;
    if fee_amount > 0 {
        new_caller.debit(fee_amount)?;
        overlay.insert(caller_key.clone(), new_caller);
    }

    // T4.9.1: Execute contract call in overlay
    // Convert tx::CallTransaction to contracts::call::CallTransaction and execute
    use crate::contracts::call::CallTransaction as ContractCallTransaction;
    use crate::contracts::gas::GasMeter;
    use crate::core::contracts::runtime::{Runtime, MAX_CALL_DEPTH};

    // Default gas limit: 10M gas (can be adjusted based on fee or made configurable)
    const DEFAULT_GAS_LIMIT: u64 = 10_000_000;

    // Convert tx::CallTransaction to contracts::call::CallTransaction
    // Extract function selector (first 4 bytes) and calldata
    let function_selector = if tx.function_selector.len() >= 4 {
        let mut selector = [0u8; 4];
        selector.copy_from_slice(&tx.function_selector[0..4]);
        selector
    } else {
        // Invalid function selector
        let rc = Receipt {
            status: false,
            index,
            error: Some("invalid function selector: must be 4 bytes".into()),
            events: None,
        };
        write_rc(&rc)?;
        return Ok(rc);
    };

    // Create ContractCallTransaction from tx::CallTransaction
    let contract_call = ContractCallTransaction {
        contract_address: hex::encode(&tx.contract_address),
        function_selector,
        calldata: tx.calldata.clone(),
        caller: hex::encode(&tx.caller),
    };

    // Create Runtime with overlay and block timestamp
    let runtime = Runtime::new(
        overlay.clone(), // Clone overlay for Runtime (will sync back after execution)
        DEFAULT_GAS_LIMIT,
        MAX_CALL_DEPTH,
        block_timestamp,
    );

    // Create GasMeter
    let mut gas_meter = GasMeter::new(DEFAULT_GAS_LIMIT);

    // Execute contract call
    let execution_result =
        contract_call.execute_with_overlay(storage, &runtime, &mut gas_meter, Some(overlay));

    // Sync overlay from Runtime (Runtime may have modified its internal overlay)
    // Note: The execute() method already modifies the overlay directly, so this sync may not be needed
    // but we keep it for safety
    if let Ok(runtime_overlay) = runtime.overlay().lock() {
        for (key, account) in runtime_overlay.iter() {
            overlay.insert(key.clone(), *account);
        }
    }

    // T4.9.2: Commit contract storage changes
    // Contract storage changes are made to ContractStorage overlay during execution.
    // The overlay is now automatically committed to the database through the runtime.
    let contract_storage = runtime.contract_storage();
    contract_storage.commit_to_database(storage)?;
    
    // The contract storage root is now included in the global state root calculation.

    // T4.9.3: Event emission integration
    // Raccogli eventi emessi durante l'esecuzione dal runtime EventSystem
    let event_system = runtime.event_system();
    let standard_events = event_system.get_standard_events();
    let custom_events = event_system.get_custom_events();

    // Converti eventi standard e custom in ReceiptEvent
    let mut receipt_events = Vec::new();

    // Converti eventi standard
    use crate::contracts::events::StandardEvent;

    for std_event in standard_events {
        let (event_name, contract_address, topics, data) = match std_event {
            StandardEvent::OwnershipTransferred {
                previous_owner,
                new_owner,
            } => {
                // Topic 0: keccak256("OwnershipTransferred(address,address)")
                let signature = b"OwnershipTransferred(address,address)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                // Topic 1: previous_owner (padded to 32 bytes)
                let mut topic1 = vec![0u8; 32];
                if let Ok(prev_bytes) = hex::decode(&previous_owner) {
                    if prev_bytes.len() <= 32 {
                        topic1[32 - prev_bytes.len()..].copy_from_slice(&prev_bytes);
                    }
                }

                // Topic 2: new_owner (padded to 32 bytes)
                let mut topic2 = vec![0u8; 32];
                if let Ok(new_bytes) = hex::decode(&new_owner) {
                    if new_bytes.len() <= 32 {
                        topic2[32 - new_bytes.len()..].copy_from_slice(&new_bytes);
                    }
                }

                (
                    "OwnershipTransferred".to_string(),
                    hex::decode(&previous_owner)
                        .ok()
                        .and_then(|b| {
                            if b.len() == 32 {
                                let mut addr = [0u8; 32];
                                addr.copy_from_slice(&b);
                                Some(hex::encode(addr))
                            } else {
                                None
                            }
                        })
                        .unwrap_or_else(|| previous_owner.clone()),
                    vec![topic0_bytes, topic1, topic2],
                    vec![],
                )
            }
            StandardEvent::Paused { account } => {
                let signature = b"Paused(address)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                let mut topic1 = vec![0u8; 32];
                if let Ok(acc_bytes) = hex::decode(&account) {
                    if acc_bytes.len() <= 32 {
                        topic1[32 - acc_bytes.len()..].copy_from_slice(&acc_bytes);
                    }
                }

                (
                    "Paused".to_string(),
                    account.clone(),
                    vec![topic0_bytes, topic1],
                    vec![],
                )
            }
            StandardEvent::Unpaused { account } => {
                let signature = b"Unpaused(address)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                let mut topic1 = vec![0u8; 32];
                if let Ok(acc_bytes) = hex::decode(&account) {
                    if acc_bytes.len() <= 32 {
                        topic1[32 - acc_bytes.len()..].copy_from_slice(&acc_bytes);
                    }
                }

                (
                    "Unpaused".to_string(),
                    account.clone(),
                    vec![topic0_bytes, topic1],
                    vec![],
                )
            }
            StandardEvent::Upgraded {
                contract_address,
                new_version,
            } => {
                let signature = b"Upgraded(address,uint64)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                let mut topic1 = vec![0u8; 32];
                if let Ok(addr_bytes) = hex::decode(&contract_address) {
                    if addr_bytes.len() <= 32 {
                        topic1[32 - addr_bytes.len()..].copy_from_slice(&addr_bytes);
                    }
                }

                let mut data = vec![0u8; 32];
                data[0..8].copy_from_slice(&new_version.to_le_bytes());

                (
                    "Upgraded".to_string(),
                    contract_address,
                    vec![topic0_bytes, topic1],
                    data,
                )
            }
            StandardEvent::GovernanceHookTriggered {
                contract_address,
                proposal_id,
                action_type,
            } => {
                let signature = b"GovernanceHookTriggered(address,bytes32,string)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                let mut topic1 = vec![0u8; 32];
                if let Ok(addr_bytes) = hex::decode(&contract_address) {
                    if addr_bytes.len() <= 32 {
                        topic1[32 - addr_bytes.len()..].copy_from_slice(&addr_bytes);
                    }
                }

                let mut topic2 = vec![0u8; 32];
                if let Ok(prop_bytes) = hex::decode(&proposal_id) {
                    if prop_bytes.len() <= 32 {
                        topic2[32 - prop_bytes.len()..].copy_from_slice(&prop_bytes);
                    }
                }

                let data = action_type.as_bytes().to_vec();

                (
                    "GovernanceHookTriggered".to_string(),
                    contract_address,
                    vec![topic0_bytes, topic1, topic2],
                    data,
                )
            }
            StandardEvent::FeeHookTriggered {
                contract_address,
                caller,
                amount,
            } => {
                let signature = b"FeeHookTriggered(address,address,uint128)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                let mut topic1 = vec![0u8; 32];
                if let Ok(addr_bytes) = hex::decode(&contract_address) {
                    if addr_bytes.len() <= 32 {
                        topic1[32 - addr_bytes.len()..].copy_from_slice(&addr_bytes);
                    }
                }

                let mut topic2 = vec![0u8; 32];
                if let Ok(caller_bytes) = hex::decode(&caller) {
                    if caller_bytes.len() <= 32 {
                        topic2[32 - caller_bytes.len()..].copy_from_slice(&caller_bytes);
                    }
                }

                let mut data = vec![0u8; 32];
                data[0..16].copy_from_slice(&amount.to_le_bytes());

                (
                    "FeeHookTriggered".to_string(),
                    contract_address,
                    vec![topic0_bytes, topic1, topic2],
                    data,
                )
            }
            StandardEvent::CallbackTriggered {
                callback_id,
                payload_hash,
                payload,
            } => {
                let signature = b"CallbackTriggered(bytes32,bytes32)";
                let mut hasher = Keccak256::new();
                hasher.update(signature);
                let topic0 = hasher.finalize();
                let mut topic0_bytes = vec![0u8; 32];
                topic0_bytes.copy_from_slice(&topic0);

                let mut topic1 = vec![0u8; 32];
                if let Ok(callback_bytes) = hex::decode(&callback_id) {
                    if callback_bytes.len() <= 32 {
                        topic1[32 - callback_bytes.len()..].copy_from_slice(&callback_bytes);
                    }
                }

                let mut topic2 = vec![0u8; 32];
                if let Ok(hash_bytes) = hex::decode(&payload_hash) {
                    if hash_bytes.len() <= 32 {
                        topic2[32 - hash_bytes.len()..].copy_from_slice(&hash_bytes);
                    }
                }

                (
                    "CallbackTriggered".to_string(),
                    callback_id.clone(),
                    vec![topic0_bytes, topic1, topic2],
                    payload.clone(),
                )
            }
        };

        receipt_events.push(ReceiptEvent {
            contract_address,
            event_name,
            topics,
            data,
        });
    }

    // Converti eventi custom (già nel formato corretto)
    for custom_event in custom_events {
        receipt_events.push(ReceiptEvent {
            contract_address: custom_event.contract_address,
            event_name: custom_event.event_name,
            topics: custom_event.topics.iter().map(|t| t.to_vec()).collect(),
            data: custom_event.data,
        });
    }

    let events = if receipt_events.is_empty() {
        None
    } else {
        Some(receipt_events)
    };

    // Handle execution result
    let rc = match execution_result {
        Ok(_return_data) => {
            // Execution successful
            Receipt {
                status: true,
                index,
                error: None,
                events,
            }
        }
        Err(e) => {
            // Execution failed - fee is still deducted (DoS prevention, like Ethereum)
            Receipt {
                status: false,
                index,
                error: Some(format!("contract execution failed: {}", e)),
                events,
            }
        }
    };

    write_rc(&rc)?;
    Ok(rc)
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::core::{generate_keypair, sign_data};
    use std::fs;
    use std::path::PathBuf;
    use std::time::{SystemTime, UNIX_EPOCH};

    fn unique_tmp_dir() -> anyhow::Result<PathBuf> {
        let nanos = SystemTime::now().duration_since(UNIX_EPOCH)?.as_nanos();
        let mut p = std::env::temp_dir();
        p.push(format!("savitri-tx-test-{}", nanos));
        fs::create_dir_all(&p)?;
        Ok(p)
    }

    fn make_signed_tx(
        from_pub: [u8; 32],
        to: Vec<u8>,
        amount: u128,
        kp: &ed25519_dalek::Keypair,
    ) -> SignedTx {
        let mut tx = SignedTx {
            from: from_pub.to_vec(),
            to,
            amount,
            nonce: 0,
            fee: None,
            pubkey: from_pub,
            sig: [0u8; 64],
            pre_verified: false,
        };
        let msg = tx.message();
        let sig = sign_data(kp, &msg);
        tx.sig.copy_from_slice(&sig.to_bytes());
        tx
    }

    #[test]
    fn valid_tx_updates_state_and_emits_ok_receipt() -> anyhow::Result<()> {
        let tmp = unique_tmp_dir()?;
        let store = Storage::new(&tmp)?;

        // Fund sender
        let kp = generate_keypair();
        let from_pub = kp.public.to_bytes();
        let funder = Account { balance: 1_000_000, nonce: 0 };
        let to_addr = b"to-addr".to_vec();

        let mut batch = store.begin_batch();
        batch.put_account(&from_pub, &funder)?;
        batch.commit()?;

        // Apply tx
        let tx = make_signed_tx(from_pub, to_addr.clone(), 12345, &kp);
        let tx_bytes = bincode::serialize(&tx)?;
        let mut batch2 = store.begin_batch();
        let rc = apply_signed_tx(&store, &mut batch2, &tx_bytes, 1)?;
        assert!(rc.status);
        batch2.commit()?;

        // Verify balances
        let from_acc = store.get_account(from_pub)?;
        assert_eq!(from_acc.balance, funder.balance - 12345);
        let to_acc = store.get_account(&to_addr)?;
        assert_eq!(to_acc.balance, 12345);
        Ok(())
    }

