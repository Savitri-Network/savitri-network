    #[test]
    fn fee_deduction_from_sender() -> anyhow::Result<()> {
        let tmp = unique_tmp_dir()?;
        let store = Storage::new(&tmp)?;

        let kp = generate_keypair();
        let from_pub = kp.public.to_bytes();
        let to_addr = b"bob".to_vec();

        // Fund sender with enough balance for amount + fee
        let initial_balance = 1_000_000_000_000_000_000; // 1 token
        let mut batch = store.begin_batch();
        batch.put_account(
            &from_pub,
            &Account {
                balance: initial_balance,
                nonce: 0,
            },
        )?;
        batch.commit()?;

        // Create tx with amount and fee
        let amount = 100_000_000_000_000_000; // 0.1 token
        let fee = 200_000_000_000_000_000; // 0.2 token
        let mut tx = make_signed_tx(from_pub, to_addr.clone(), amount, &kp);
        tx.fee = Some(fee);

        let mut batch2 = store.begin_batch();
        let rc = apply_signed_tx(&store, &mut batch2, &bincode::serialize(&tx)?, 16)?;
        assert!(rc.status);
        batch2.commit()?;

        // Verify balances: sender should have balance - amount - fee
        let from_acc = store.get_account(from_pub)?;
        assert_eq!(from_acc.balance, initial_balance - amount - fee);

        // Receiver should have only the amount (not the fee)
        let to_acc = store.get_account(&to_addr)?;
        assert_eq!(to_acc.balance, amount);
        Ok(())
    }

