    #[test]
    fn fee_deduction_checked_arithmetic_prevents_overflow() -> anyhow::Result<()> {
        let tmp = unique_tmp_dir()?;
        let store = Storage::new(&tmp)?;

        let kp = generate_keypair();
        let from_pub = kp.public.to_bytes();
        let to_addr = b"bob".to_vec();

        // Fund sender with maximum balance
        let mut batch = store.begin_batch();
        batch.put_account(&from_pub, &Account { balance: u128::MAX, nonce: 0 })?;
        batch.commit()?;

        // Create tx with amount that would cause overflow when adding fee
        // Use a valid fee (>= min_fee) and amount such that amount + fee > u128::MAX
        let fee = DEFAULT_FEE_LIMITS.min_fee; // Valid fee
        let amount = u128::MAX - fee + 1; // This will cause overflow: amount + fee = u128::MAX + 1
        let mut tx = make_signed_tx(from_pub, to_addr, amount, &kp);
        tx.fee = Some(fee);

        let mut batch2 = store.begin_batch();
        let rc = apply_signed_tx(&store, &mut batch2, &bincode::serialize(&tx)?, 20)?;
        // Should fail because amount + fee would overflow
        assert!(!rc.status);
        assert!(rc.error.is_some());
        let error_msg = rc.error.unwrap();
        // Check for overflow error message (can be "total required overflow" or "exceeds u128::MAX")
        assert!(
            error_msg.contains("overflow") || error_msg.contains("exceeds u128::MAX"),
            "Expected overflow error, got: {}",
            error_msg
        );
        batch2.commit()?;
        Ok(())
    }
}

/// Calculate contract address from deployer address and nonce
pub fn calculate_contract_address(deployer: &[u8], nonce: u64) -> Vec<u8> {
    let mut hasher = Keccak256::new();
    hasher.update(deployer);
    hasher.update(&nonce.to_le_bytes());
    hasher.update(b"contract_deploy");
    
    let hash = hasher.finalize();
    hash[12..].to_vec() // Take last 20 bytes (Ethereum-style address)
}

/// Execute contract constructor with bytecode and arguments
pub fn execute_contract_constructor(
    bytecode: &[u8],
    constructor_args: &[u8],
    contract_address: &[u8],
    deployer: &[u8],
    storage: &Storage,
) -> Result<ConstructorResult, anyhow::Error> {
    // Simulate constructor execution
    // In a real implementation, this would use the EVM or WASM runtime
    
    let mut hasher = Sha256::new();
    hasher.update(bytecode);
    hasher.update(constructor_args);
    hasher.update(contract_address);
    hasher.update(deployer);
    
    let initial_state = hasher.finalize().to_vec();
    let gas_used = bytecode.len() as u64 * 50 + constructor_args.len() as u64 * 10; // Simple gas estimation
    
    Ok(ConstructorResult {
        initial_state,
        gas_used,
    })
}

/// Execute contract call with function selector and calldata
pub fn execute_contract_call(
    contract_address: &[u8],
    function_selector: &[u8],
    calldata: &[u8],
    caller: &[u8],
    storage: &Storage,
) -> Result<CallResult, anyhow::Error> {
    // Simulate contract call execution
    // In a real implementation, this would use the EVM or WASM runtime
    
    let mut hasher = Sha256::new();
    hasher.update(contract_address);
    hasher.update(function_selector);
    hasher.update(calldata);
    hasher.update(caller);
    
    let new_state = hasher.finalize().to_vec();
    
    // Simulate return data based on function selector
    let return_data = if function_selector.len() >= 4 {
        match &function_selector[0..4] {
            [0x01, 0x23, 0x45, 0x67] => b"success".to_vec(),
            [0xab, 0xcd, 0xef, 0x01] => caller.to_vec(),
            _ => vec![0x00],
        }
    } else {
        vec![0x00]
    };
    
    let gas_used = calldata.len() as u64 * 20 + function_selector.len() as u64 * 10; // Simple gas estimation
    
    Ok(CallResult {
        new_state,
        return_data,
        gas_used,
    })
}
